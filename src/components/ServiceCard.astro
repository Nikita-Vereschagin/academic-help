---
interface Props {
  service: {
    id: string;
    name: string;
    time: string;
    difficulty: number;
    priceExplain?: number;
    priceFull?: number;
    priceExtra?: number;
    note?: string;
  };
  categoryName: string;
}
const { service, categoryName } = Astro.props;
const TG_USERNAME = "helper_fbi";
// Форматируем цену
const fmt = (n?: number) => (n ? `${n} ₽` : "договорная");

// Генерируем текст для Telegram
const getMessage = () => {
  let text = `Здравствуйте! Хочу заказать:\nПредмет: ${categoryName}\nРабота: ${service.name} \n`;
  if (service.note) text += `\nПримечание: ${service.note}`;
  text += `\n\nТема/вариант: \nДоп. требования: \n`;
  return encodeURIComponent(text);
};
---

<article
  class="bg-white rounded-xl shadow-md overflow-hidden hover:shadow-lg duration-300 flex flex-col h-full"
>
  <div class="p-5 flex-1">
    <div class="flex justify-between items-start mb-2">
      <h4 class="font-semibold text-gray-900">{service.name}</h4>
    </div>

    {/* Сложность */}
    <div class="flex items-center gap-2 mb-3">
      <span class="text-xs text-gray-500">Сложность:</span>
      <div class="flex gap-0.5">
        {
          Array.from({ length: 10 }).map((_, i) => (
            <div
              class={`w-2 h-2 rounded-sm ${i < service.difficulty ? "bg-amber-400" : "bg-gray-200"}`}
            />
          ))
        }
      </div>
      <span class="text-xs text-gray-500">{service.difficulty}/10</span>
    </div>

    {/* Время */}
    <p class="text-sm text-gray-600 mb-3">Время: {service.time}</p>

    {/* Цены */}
    <div class="space-y-1 mb-4">
      {
        service.priceExplain && (
          <div class="flex justify-between text-sm">
            <span class="text-gray-600">Объяснение:</span>
            <span class="font-medium text-blue-600">
              {fmt(service.priceExplain)}
            </span>
          </div>
        )
      }
      {
        service.priceFull && (
          <div class="flex justify-between text-sm">
            <span class="text-gray-600">Выполнение:</span>
            <span class="font-medium text-green-600">
              {fmt(service.priceFull)}
            </span>
          </div>
        )
      }
      {
        service.priceExtra && (
          <div class="flex justify-between text-sm">
            <span class="text-gray-600">Дополнительное задание:</span>
            <span class="font-medium text-purple-600">
              {fmt(service.priceExtra)}
            </span>
          </div>
        )
      }
      {
        service.note && (
          <p class="text-xs text-gray-500 italic mt-2">{service.note}</p>
        )
      }
    </div>
  </div>

  <div class="px-5 pb-5">
    <button
      id={`order-btn-${service.id}`}
      data-service-id={service.id}
      data-tg-username={TG_USERNAME}
      data-message={getMessage()}
      data-price-full={service.priceFull ?? ""}
      data-price-explain={service.priceExplain ?? ""}
      data-price-extra={service.priceExtra ?? ""}
      class="block w-full text-center bg-blue-600 hover:bg-blue-700 text-white font-medium py-2 px-4 rounded-lg duration-500 hover:shadow-lg hover:scale-x-105 disabled:bg-gray-400 disabled:hover:bg-gray-400"
    >
      Заказать в Telegram
    </button>
  </div>

  <!-- Modal -->
  <div
    id={`modal-${service.id}`}
    class="fixed inset-0 z-50 hidden items-center justify-center bg-black bg-opacity-50 grid-rows-[auto_50px] p-4"
    onclick="if (event.target === this && !event.target.closest('#modal-content')) { this.classList.add('hidden'); this.classList.remove('flex'); }"
  >
    <div
      id="modal-content"
      class="bg-white rounded-lg shadow-lg w-full max-w-md p-6"
    >
      <h3 class="text-lg font-semibold mb-3">Укажите дедлайн</h3>
      <span class="text-sm text-gray-500 mb-4 block">
        Наценка будет рассчитываться автоматически в зависимости от оставшегося
        времени до дедлайна.
      </span>
      <label class="text-sm text-gray-600">Срок сдачи</label>
      <input
        id={`deadline-input-${service.id}`}
        type="date"
        class="w-full border rounded p-2 mt-1 mb-3"
      />

      <div class="text-sm text-gray-700 mb-3">
        <div>Наценка: <span id={`surcharge-${service.id}`}>—</span></div>
        <div>
          Итоговая цена (выполнение): <span id={`price-full-${service.id}`}
            >{service.priceFull ? fmt(service.priceFull) : "—"}</span
          >
        </div>
        {
          service.priceExplain && (
            <div>
              Итоговая цена (объяснение):{" "}
              <span id={`price-explain-${service.id}`}>
                {fmt(service.priceExplain)}
              </span>
            </div>
          )
        }
        {
          service.priceExtra && (
            <div>
              Итоговая цена (доп.):{" "}
              <span id={`price-extra-${service.id}`}>
                {fmt(service.priceExtra)}
              </span>
            </div>
          )
        }
      </div>
      <p class="text-xs text-gray-500 mt-2">
        Не забудьте прикрепить файлы с заданием и примером вашей работы. Укажите
        тему/вариант, если нужно, и дополнительные требования к выполнению.
      </p>

      <div class="mt-4 flex gap-2">
        <a
          id={`send-tg-${service.id}`}
          class="flex-1 text-center bg-green-600 hover:bg-green-700 text-white py-2 rounded duration-500 disabled:bg-gray-400 disabled:hover:bg-gray-400"
          rel="noopener"
          target="_blank">Отправить в Telegram</a
        >
        <button
          id={`close-modal-${service.id}`}
          class="px-4 py-2 rounded border hover:bg-gray-200 duration-500 text-gray-700"
          >Отмена</button
        >
      </div>
    </div>
  </div>
</article>

<script type="module">
  // Инициализируем модалы для всех кнопок с data-service-id
  const buttons = document.querySelectorAll("button[data-service-id]");
  buttons.forEach((btn) => {
    const SERVICE_ID = btn.dataset.serviceId;
    const modal = document.getElementById("modal-" + SERVICE_ID);
    if (!modal) return;
    const closeBtn = modal.querySelector("#close-modal-" + SERVICE_ID);
    const input = modal.querySelector("#deadline-input-" + SERVICE_ID);
    const surchargeEl = modal.querySelector("#surcharge-" + SERVICE_ID);
    const priceFullEl = modal.querySelector("#price-full-" + SERVICE_ID);
    const priceExplainEl = modal.querySelector("#price-explain-" + SERVICE_ID);
    const priceExtraEl = modal.querySelector("#price-extra-" + SERVICE_ID);
    const sendLink = modal.querySelector("#send-tg-" + SERVICE_ID);

    const parsePrice = (v) => {
      const n = Number(v);
      return Number.isFinite(n) && n > 0 ? n : null;
    };
    const baseFull = parsePrice(btn.dataset.priceFull);
    const baseExplain = parsePrice(btn.dataset.priceExplain);
    const baseExtra = parsePrice(btn.dataset.priceExtra);
    const TG = btn.dataset.tgUsername || "helper_fbi";

    const calcSurcharge = (deadline) => {
      const now = new Date();
      const diffMs = deadline - now;
      if (diffMs < 0) return { percent: null, reason: "Дедлайн уже прошёл" };
      const msPerDay = 1000 * 60 * 60 * 24;
      const daysRemaining = Math.ceil(diffMs / msPerDay);
      if (daysRemaining > 7) return { percent: 0 };
      const percent = 10 * (1 + (7 - daysRemaining));
      return { percent };
    };

    const formatRub = (n) => (n ? `${Math.round(n)} ₽` : "договорная");

    const updatePrices = () => {
      const val = input.value;
      if (!val) {
        surchargeEl.textContent = "—";
        if (baseFull) priceFullEl.textContent = formatRub(baseFull);
        if (baseExplain && priceExplainEl)
          priceExplainEl.textContent = formatRub(baseExplain);
        if (baseExtra && priceExtraEl)
          priceExtraEl.textContent = formatRub(baseExtra);
        sendLink.href = "#";
        return;
      }
      const deadline = new Date(val);
      const res = calcSurcharge(deadline);
      if (res.percent === null) {
        surchargeEl.textContent = res.reason;
        sendLink.href = "#";
        return;
      }
      surchargeEl.textContent = res.percent + "%";
      if (baseFull)
        priceFullEl.textContent = formatRub(baseFull * (1 + res.percent / 100));
      if (baseExplain && priceExplainEl)
        priceExplainEl.textContent = formatRub(
          baseExplain * (1 + res.percent / 100),
        );
      if (baseExtra && priceExtraEl)
        priceExtraEl.textContent = formatRub(
          baseExtra * (1 + res.percent / 100),
        );

      const baseMsg = btn.dataset.message || "";
      const dateStr = deadline.toLocaleString();
      const finalPrices = [];
      if (baseFull)
        finalPrices.push(
          `Выполнение: ${formatRub(Math.round(baseFull * (1 + res.percent / 100)))}`,
        );
      if (baseExplain)
        finalPrices.push(
          `Объяснение: ${formatRub(Math.round(baseExplain * (1 + res.percent / 100)))}`,
        );
      if (baseExtra)
        finalPrices.push(
          `Доп.: ${formatRub(Math.round(baseExtra * (1 + res.percent / 100)))}`,
        );
      const text = `${decodeURIComponent(baseMsg)}\nСрок сдачи: ${dateStr}\n${finalPrices.join("\n")}\nНаценка: ${res.percent}%`;
      const href = `https://t.me/${TG}?text=${encodeURIComponent(text)}`;
      sendLink.href = href;
    };

    btn.addEventListener("click", (e) => {
      e.preventDefault();
      modal.classList.remove("hidden");
      modal.classList.add("flex");
    });
    closeBtn &&
      closeBtn.addEventListener("click", () => {
        modal.classList.add("hidden");
        modal.classList.remove("flex");
      });
    input && input.addEventListener("change", updatePrices);
    btn.addEventListener("mouseenter", updatePrices);
  });
</script>
