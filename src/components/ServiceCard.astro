---
interface Props {
  service: {
    id: string;
    name: string;
    time: string;
    difficulty: number;
    priceExplain?: number;
    priceFull?: number;
    priceExtra?: number;
    note?: string;
  };
  categoryName: string;
}
const { service, categoryName } = Astro.props;
const TG_USERNAME = "helper_fbi";

// Форматируем цену
const fmt = (n?: number) => (n ? `${n} ₽` : "договорная");

// Генерируем текст для Telegram
const getMessage = () => {
  let text = `Здравствуйте! Хочу заказать:\nПредмет: ${categoryName}\nРабота: ${service.name} (${service.id})\nВремя: ${service.time}\nСложность: ${service.difficulty}/10\n`;
  if (service.priceExplain && service.priceFull) {
    text += `\nПрайс:\n• Объяснение: ${fmt(service.priceExplain)}\n• Выполнение: ${fmt(service.priceFull)}`;
  } else if (service.priceFull) {
    text += `\nВыполнение: ${fmt(service.priceFull)}`;
  }
  if (service.note) text += `\nПримечание: ${service.note}`;
  text += `\n\nПредмет/вариант: \nСрок сдачи: \nДоп. требования: `;
  return encodeURIComponent(text);
};
const telegramLink = `https://t.me/${TG_USERNAME}?text=${getMessage()}`;
---

<article
  class="bg-white rounded-xl shadow-md overflow-hidden hover:shadow-lg transition flex flex-col h-full"
>
  <div class="p-5 flex-1">
    <div class="flex justify-between items-start mb-2">
      <h4 class="font-semibold text-gray-900">{service.name}</h4>
      <span class="text-xs bg-gray-100 px-2 py-1 rounded text-gray-600"
        >{service.id}</span
      >
    </div>

    {/* Сложность */}
    <div class="flex items-center gap-2 mb-3">
      <span class="text-xs text-gray-500">Сложность:</span>
      <div class="flex gap-0.5">
        {
          Array.from({ length: 10 }).map((_, i) => (
            <div
              class={`w-2 h-2 rounded-sm ${i < service.difficulty ? "bg-amber-400" : "bg-gray-200"}`}
            />
          ))
        }
      </div>
      <span class="text-xs text-gray-500">{service.difficulty}/10</span>
    </div>

    {/* Время */}
    <p class="text-sm text-gray-600 mb-3">Время: {service.time}</p>

    {/* Цены */}
    <div class="space-y-1 mb-4">
      {
        service.priceExplain && (
          <div class="flex justify-between text-sm">
            <span class="text-gray-600">Объяснение:</span>
            <span class="font-medium text-blue-600">
              {fmt(service.priceExplain)}
            </span>
          </div>
        )
      }
      {
        service.priceFull && (
          <div class="flex justify-between text-sm">
            <span class="text-gray-600">Выполнение:</span>
            <span class="font-medium text-green-600">
              {fmt(service.priceFull)}
            </span>
          </div>
        )
      }
      {
        service.priceExtra && (
          <div class="flex justify-between text-sm">
            <span class="text-gray-600">Дополнительное задание:</span>
            <span class="font-medium text-purple-600">
              {fmt(service.priceExtra)}
            </span>
          </div>
        )
      }
      {
        service.note && (
          <p class="text-xs text-gray-500 italic mt-2">{service.note}</p>
        )
      }
    </div>
  </div>

  <div class="px-5 pb-5">
    <a
      href={telegramLink}
      target="_blank"
      rel="noopener"
      class="block w-full text-center bg-blue-600 hover:bg-blue-700 text-white font-medium py-2 px-4 rounded-lg transition"
    >
      Заказать в Telegram
    </a>
  </div>
</article>
