---
import Layout from "../layouts/Layout.astro";
import ServiceCard from "../components/ServiceCard.astro";
import data from "../data/services.json";

// Для простоты: рендерим все категории сразу
// Позже можно добавить клиентский фильтр через Astro Islands
---

<Layout title="FBI Answers — Помощь с учебными работами">
  <!-- Hero -->
  <section
    class="bg-gradient-to-r from-blue-600 to-indigo-700 text-white py-16 px-4"
  >
    <div class="max-w-6xl mx-auto text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">
        Помощь с учебными заданиями
      </h2>
      <p class="text-lg opacity-90 max-w-2xl mx-auto">
        Лабораторные, практические, РГЗ, ИДЗ — объясним или выполним под ключ.
        Конфиденциально, в срок, с гарантией.
      </p>
      <a
        href="https://t.me/helper_fbi"
        target="_blank"
        class="inline-block mt-6 bg-white text-blue-700 font-semibold py-3 px-6 rounded-lg hover:bg-gray-100 transition"
      >
        Написать администратору
      </a>
    </div>
  </section>

  <!-- Каталог по категориям -->
  {
    data.courses.map((course, i) => (
      <>
        <h2 class=" text-3xl font-bold text-gray-900 mt-10 mb-6 text-center">
          {"КУРС " + (i + 1)}
        </h2>
        {course.categories.map((category) => (
          <section class="max-w-6xl mx-auto px-4 py-10">
            <h3 class="text-2xl font-bold text-gray-900 mb-6">
              {category.name}
            </h3>
            {category.services.map((term, i) => (
              <>
                {category.services.length > 1 && (
                  <h4 class="text-xl font-semibold text-gray-800 mt-4 mb-4">
                    {i === 0 ? "1 семестр" : i === 1 ? "2 семестр" : ""}
                  </h4>
                )}
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5">
                  {(Array.isArray(term) ? term : [term]).map((service) => (
                    <ServiceCard
                      service={service}
                      categoryName={category.name}
                    />
                  ))}
                </div>
              </>
            ))}
          </section>
        ))}
      </>
    ))
  }

  <!-- Footer info -->
  <section class="bg-gray-50 py-10 px-4">
    <div class="max-w-6xl mx-auto text-center text-sm text-gray-600 space-y-2">
      <p>
        Время указано для выполнения «с нуля» без вспомогательных материалов
      </p>
      <p>
        Все вопросы: <a
          href="https://t.me/helper_fbi"
          class="text-blue-600 hover:underline">@helper_fbi</a
        >
      </p>
      <p>
        Наш чат: <a
          href={data.contact.chatLink}
          class="text-blue-600 hover:underline"
          target="_blank">FBI Answers</a
        >
      </p>
    </div>
  </section>
</Layout>
